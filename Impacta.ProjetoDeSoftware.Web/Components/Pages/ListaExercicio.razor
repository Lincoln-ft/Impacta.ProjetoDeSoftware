@page "/exercicios"
@using Impacta.ProjetoDeSoftware.Web.Services
@using Impacta.ProjetoDeSoftware.Web.Models
@inject ExercicioService service

<PageTitle>Lista de Exercícios</PageTitle>

<div class="exercicios-container">
    <h1 class="title">💪 Lista de Exercícios</h1>

    <div class="card-actions">
        <div class="card">
            <h3>➕ Novo Exercício</h3>
            <p>Cadastre um novo exercício.</p>
            <NavLink class="nav-link" href="cadastrar-exercicio">
                <button class="btn">
                    <span class="bi bi-plus-circle" aria-hidden="true"></span> Cadastrar Exercício
                </button>
            </NavLink>
        </div>
    </div>

    @if (exercicios == null || exercicios.Count == 0)
    {
        <p class="empty-msg">Nenhum exercício cadastrado ainda.</p>
    }
    else
    {
        <table class="exercicios-table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Link do Vídeo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in exercicios)
                {
                    <tr>
                        <td>@e.Nome</td>
                        <td>
                            <a href="@e.LinkVideo" target="_blank" class="video-link">Assistir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Exercicio> exercicios = new();

    protected override async Task OnInitializedAsync()
    {
        exercicios = await service.GetExerciciosAsync();
    }
}

<style>
    .exercicios-container {
        padding: 40px;
        background: #f5f7fa;
        min-height: 100vh;
    }

    .title {
        text-align: center;
        font-size: 2.5rem;
        margin-bottom: 30px;
        color: #2a5298;
        font-weight: bold;
    }

    .exercicios-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }

    .exercicio-card {
        background: #fff;
        border-radius: 10px;
        padding: 20px;
        width: 320px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        text-align: center;
    }

    .video-wrapper {
        margin-top: 15px;
    }

    iframe {
        border-radius: 8px;
    }
    .card-actions {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
    }

    .card {
        background: #fff;
        color: #333;
        border-radius: 10px;
        padding: 20px;
        width: 280px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: transform 0.2s;
        text-align: center;
    }

        .card:hover {
            transform: scale(1.05);
        }

    .btn {
        margin-top: 15px;
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        background: #2a5298;
        color: #fff;
        cursor: pointer;
        font-weight: bold;
    }

        .btn:hover {
            background: #1e3c72;
        }

    .empty-msg {
        text-align: center;
        font-size: 1.2rem;
        color: #777;
    }

    .exercicios-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border-radius: 8px;
        overflow: hidden;
    }

        .exercicios-table th {
            background: #2a5298;
            color: #fff;
            padding: 12px;
            text-align: left;
        }

        .exercicios-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
        }

        .exercicios-table tr:hover {
            background: #f0f4ff;
        }

    .video-link {
        color: #2a5298;
        font-weight: bold;
        text-decoration: none;
    }

        .video-link:hover {
            text-decoration: underline;
        }
</style>
